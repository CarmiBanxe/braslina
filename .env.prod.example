# Braslina Production Environment
BRASLINA_ENV=production
BRASLINA_API_KEY=CHANGE_ME_STRONG_KEY

# Database
POSTGRES_USER=braslina
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=braslina
DATABASE_URL=postgresql+asyncpg://braslina:CHANGE_ME@braslina-db:5432/braslina

# Redis
REDIS_URL=redis://:CHANGE_ME@braslina-redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# MinIO
MINIO_ENDPOINT=braslina-minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

# Rate Limiting
BRASLINA_RATE_LIMIT=60
BRASLINA_RATE_WINDOW=60

# Idempotency
BRASLINA_IDEMPOTENCY_TTL=86400
